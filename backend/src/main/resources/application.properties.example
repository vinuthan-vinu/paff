# ============================================
# Smart Campus Operations Hub - Configuration
# ============================================

# --- Server ---
server.port=8080

# --- MySQL Database ---
spring.datasource.url=jdbc:mysql://localhost:3306/smartcampus
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD_HERE
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# --- JPA / Hibernate ---
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# --- JWT Configuration ---
app.jwt.secret=SmartCampusHubSecretKeyForJWTTokenGenerationMustBeLongEnough2024SecureKey
app.jwt.expiration-ms=86400000

# --- File Upload ---
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=5MB
spring.servlet.multipart.max-request-size=15MB
app.upload.dir=./uploads

# --- CORS ---
app.cors.allowed-origins=http://localhost:5173

# --- Google OAuth ---
spring.security.oauth2.client.registration.google.client-id=821740270628-ria9prpc0dnag8hi4h60mj0lknp6984a.apps.googleusercontent.com
